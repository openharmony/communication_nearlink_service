{
    "process": "nearlink_service",
    "systemability": [
        {
            "name": 1190,
            "libpath": "libnearlink_server.z.so",
            "run-on-create": false,
            "auto-restart": true,
            "distributed": false,
            "dump-level": 1,
            "min_hdi_proxy_version": ["libnearlink_hci_proxy_1.0.z.so"],
            "start-on-demand":{
                "param":[
                    {
                        "name":"persist.nearlink.switch_enable",
                        "value":"1",
                        "conditions":[
                            {
                                "eventId":"param",
                                "name":"const.nearlink.enable",
                                "value":"true"
                            }
                        ]
                    },
                    {
                        "name":"persist.nearlink.switch_enable",
                        "value":"2",
                        "conditions":[
                            {
                                "eventId":"param",
                                "name":"const.nearlink.enable",
                                "value":"true"
                            }
                        ]
                    },
                    {
                        "name":"persist.nearlink.reload_sa",
                        "value":"1",
                        "conditions":[
                            {
                                "eventId":"param",
                                "name":"const.nearlink.enable",
                                "value":"true"
                            }
                        ]
                    },
                    {
                        "name":"persist.bluetooth.collaboration_service",
                        "value":"1",
                        "conditions":[
                            {
                                "eventId":"param",
                                "name":"const.nearlink.enable",
                                "value":"true"
                            }
                        ]
                    }
                ],
                "commonevent":[]
            }
        }
    ]
}