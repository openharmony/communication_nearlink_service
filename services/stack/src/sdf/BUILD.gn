import("../../../../nearlink_config.gni")

config("nearlink_sdf_config") {
  include_dirs = [
    "$NEARLINK_ROOT/services/stack/src/sdf/bsl/dsl/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/bsl/stm/include",
    "$NEARLINK_ROOT/services/stack/src/dli/dft/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/dfx/errno/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/dfx/log/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/dfx/trace/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/oal/evc/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/oal/memm/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/oal/sig/lock/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/oal/thread/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/oal/timer/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/sdffwk/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/utils/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/interface",
  ]
}

config("nearlink_sdf_public_config") {
  include_dirs = [
    "$NEARLINK_ROOT/services/stack/src/sdf/bsl/dsl/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/bsl/stm/include",
    "$NEARLINK_ROOT/services/stack/src/dli/dft/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/dfx/errno/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/dfx/log/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/dfx/trace/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/oal/evc/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/oal/memm/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/oal/sig/lock/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/oal/thread/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/oal/timer/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/sdffwk/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/utils/include",
    "$NEARLINK_ROOT/services/stack/src/sdf/interface",
  ]
}

nearlink_sdf_sources = [
    "bsl/dsl/src/sdf_buff.c",
    "bsl/dsl/src/sdf_dlist.c",
    "bsl/dsl/src/sdf_map.c",
    "bsl/dsl/src/sdf_slist.c",
    "bsl/dsl/src/sdf_vector.c",
    "bsl/stm/src/sdf_stm.c",
    "dfx/errno/src/sdf_errno.c",
    "dfx/log/src/sdf_log_api.c",
    "dfx/trace/src/sdf_trace.c",
    "oal/evc/src/sdf_evc.c",
    "oal/evc/src/sdf_event.c",
    "oal/memm/src/sdf_mem.c",
    "oal/sig/lock/src/lock_mutex.c",
    "oal/sig/lock/src/lock_sem.c",
    "oal/sig/lock/src/sdf_sem.c",
    "oal/thread/src/sdf_thread.c",
    "oal/thread/src/sdf_worker.c",
    "oal/timer/src/sdf_timer.c",
    "sdffwk/src/sdf_util.c",
    "utils/src/sdf_addr.c",
    "utils/src/sdf_string.c",
  ]

ohos_shared_library("nearlink_stack_sdf") {
  branch_protector_ret = "pac_ret"  # Enable PAC CFI
  
  ldflags = [
    "-flto",
    "-Wl,--gc-sections",
  ]

  sanitize = {
    cfi = true                             # Enable/disable control flow integrity detection
    cfi_vcall_icall_only = true            # CFI optimization, limit CFI check scope
    boundary_sanitize = true               # Enable boundary san detection
    cfi_cross_dso = true                   # Cross-SO CFI Checks
    integer_overflow = true                # Enable integer overflow detection
    ubsan = true                           # Enable some Ubsan options
    debug = false
  }

  cflags = [
    "-Wno-implicit-fallthrough",
    "-D_POSIX_C_SOURCE=200112L",
    "-D_GNU_SOURCE",
    "-Os",
    "-D_FORTIFY_SOURCE=2",
    "-fdata-sections",
    "-ffunction-sections",
    "-fno-asynchronous-unwind-tables",
    "-fno-unwind-tables",
    "-fno-exceptions",
    "-fno-rtti",
    "-flto",
  ]

  if (build_variant == "user") {
    cflags += [ "-DIS_NL_RELEASE_VERSION" ]
  }

  cflags_cc = cflags

  defines =  [
    "LOG_TAG = \"nearlink_stack_sdf\"",
    "LOG_DOMAIN = 0xD000153",
  ]
  defines += product_defines

  configs = [ ":nearlink_sdf_config" ]
  public_configs = [ ":nearlink_sdf_public_config" ]
  sources = nearlink_sdf_sources

  deps = [
    "$NEARLINK_ROOT/utils:nearlink_utils",
    "$NEARLINK_ROOT/services/dft:nearlink_dft_manager",
  ]

  external_deps = [
    "hilog:libhilog",
    "init:libbegetutil",
    "hisysevent:libhisysevent",
    "hisysevent:libhisyseventmanager",
    "bounds_checking_function:libsec_shared",
  ]

  subsystem_name = "communication"
  part_name = "nearlink_service"
}