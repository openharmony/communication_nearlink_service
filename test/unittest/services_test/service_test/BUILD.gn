import("//build/test.gni")
import("../../../../nearlink_config.gni")

config("service_unit_test_config") {
  visibility = [ ":*" ]

  include_dirs = [
    "$NEARLINK_ROOT/services/service/src/adapter",
    "$NEARLINK_ROOT/services/common/include",
    "$NEARLINK_ROOT/services/service/src/datashare",
    "$NEARLINK_ROOT/services/service/src/common",
    "$NEARLINK_ROOT/services/service/src/base",
    "$NEARLINK_ROOT/services/service/src/util",
    "$NEARLINK_ROOT/services/service/src/scan",
    "$NEARLINK_ROOT/services/service/src/collaboration",
    "$NEARLINK_ROOT/services/service/src/tws",
    "$NEARLINK_ROOT/services/hardware/include",
    "$NEARLINK_ROOT/frameworks/native/include",
    "$NEARLINK_ROOT/interfaces/inner_api/include",
    "$NEARLINK_ROOT/services/service/src/hid",
    "$NEARLINK_ROOT/services/service/src/ssap",
    "$NEARLINK_ROOT/services/service/src/asc",
    "$NEARLINK_ROOT/services/service/src/mic",
  ]

  defines =  [
    "LOG_TAG = \"nearlink_test\"",
    "LOG_DOMAIN = 0xD000151",
    "private = public"
  ]
  cflags_cc = [ "-fexceptions" ]
  cflags = [ "--coverage" ]
  ldflags = [ "--coverage" ]
}

unit_test_deps = [
  "$NEARLINK_ROOT/ipc_parcel:nearlink_ipc_parcel",
  "$NEARLINK_ROOT/utils:nearlink_utils",
  "$NEARLINK_ROOT/frameworks/native:nearlink_framework",
  "$NEARLINK_ROOT/services/common:nearlink_service_common",
  "$NEARLINK_ROOT/services/device_manager:nearlink_device_manager",
  "$NEARLINK_ROOT/services/service:nearlink_service_impl",
  "$NEARLINK_ROOT/services/stack:nearlink_stack",
  "$NEARLINK_ROOT/services/stack/src/sdf:nearlink_stack_sdf",
  "$NEARLINK_ROOT/services/hardware:nearlink_dli_adapter",
  "$NEARLINK_ROOT/services/dft:nearlink_dft_manager",
  "$NEARLINK_ROOT/test/utils:test_utils_static",
]

unit_test_external_deps = [
  "c_utils:utils",
  "hilog:libhilog",
  "ipc:ipc_core",
  "safwk:system_ability_fwk",
  "samgr:samgr_proxy",
  "huks:libhukssdk",
  "access_token:libaccesstoken_sdk",
  "access_token:libtokenid_sdk",
  "ability_base:zuri",
  "data_share:datashare_consumer",
  "ability_runtime:wantagent_innerkits",
  "googletest:gtest_main",
  "audio_framework:audio_policy_manager",
  "audio_framework:audio_engine_manager",
  "audio_framework:audio_foundation",
  "hisysevent:libhisysevent",
  "hisysevent:libhisyseventmanager",
]

test_out_path = "nearlink_service/nearlink_service"

ohos_unittest("nl_service_test") {
  module_out_path = test_out_path

  branch_protector_ret = "pac_ret"  # Enable PAC CFI
  sanitize = {
    cfi = true                             # Enable/disable control flow integrity detection
    boundary_sanitize = true               # Enable boundary san detection
    cfi_cross_dso = true                   # Cross-SO CFI Checks
    integer_overflow = true                # Enable integer overflow detection
    ubsan = true                           # Enable some Ubsan options
    debug = false
  }

  sources = [
    "nearlink_permission_manager_test.cpp",
    "nearlink_datashare_helper_test.cpp",
    "sle_switch_dependency_test.cpp",
    "sle_dli_snoop_test.cpp",
    "nearlink_timer_test.cpp",
    "hid_host_service_test.cpp",
    "hid_host_uhid_test.cpp",
    "sle_name_change_manager_test.cpp",
  ]

  configs = [ ":service_unit_test_config" ]
  configs += ["$NEARLINK_ROOT/test/utils:test_utils_config"]

  deps = unit_test_deps

  external_deps = unit_test_external_deps
  external_deps += [ "ffrt:libffrt" ]

  part_name = "nearlink"
  subsystem_name = "communication"
}

if (nearlink_service_kia_enable) {
  ohos_unittest("nl_sle_kia_manager_test") {
    module_out_path = test_out_path
    sources = [ "sle_kia_manager_test.cpp" ]

    configs = [ ":service_unit_test_config" ]
    configs += ["$NEARLINK_ROOT/test/utils:test_utils_config"]
    deps = unit_test_deps
    external_deps = unit_test_external_deps
    external_deps += [
      "ffrt:libffrt",
      "init:libbegetutil",
    ]
  }
}

if (nearlink_service_edm_enable) {
  ohos_unittest("nl_sle_edm_manager_test") {
    module_out_path = test_out_path
    sources = [ "sle_edm_manager_test.cpp" ]

    configs = [ ":service_unit_test_config" ]
    configs += ["$NEARLINK_ROOT/test/utils:test_utils_config"]
    deps = unit_test_deps
    external_deps = unit_test_external_deps
    external_deps += [
      "ffrt:libffrt",
      "init:libbegetutil",
    ]
  }
}

group("nl_service_unittest") {
  testonly = true
  deps = [
    ":nl_service_test",
    "ssap_server_test:nl_ssap_server_service_unittest",
    "ssap_client_test:nl_ssap_client_service_unittest",
    "state_machine_test:nl_adapter_state_machine_unittest",
    "tws_test:nl_tws_unittest",
    "cdsm_test:nl_cdsm_unittest",
    "nl_cloud_pair_test:nl_cloud_pair_unittest",
    "nl_reconnect_manager_test:nl_reconnect_manager_unittest",
    "nl_datatransfer_test:nl_datatransfer_unittest",
    "hadm_test:nl_hadm_service_unittest",
    "nearlink_adv_test:nl_adv_service_unittest",
    "security_adapter_test:nl_security_adapter_service_unittest",
    "vcp_test:nl_vcp_service_unittest",
    "vas_test:nl_vas_service_unittest",
    "mcp_test:nl_mcp_service_unittest",
    "ccp_test:nl_ccp_service_unittest",
    "asc_test:nl_asc_service_unittest",
    "mic_test:nl_mic_service_unittest",
    "utils_test:nl_utils_unittest",
    "manufacturer_ability_test:nl_manufacturer_ability_unittest",
    "scan_test:nl_scan_service_test",
    "audio_test:nl_audio_service_unittest",
    "icce_test:nl_icce_service_unittest",
    "dis_test:nl_dis_service_unittest",
    "bas_service_test:bas_service_unittest"
  ]
  if (nearlink_service_kia_enable) {
    deps += [
      ":nl_sle_kia_manager_test",
    ]
  }

  if (nearlink_service_edm_enable) {
    deps += [
      ":nl_sle_edm_manager_test",
    ]
  }
}