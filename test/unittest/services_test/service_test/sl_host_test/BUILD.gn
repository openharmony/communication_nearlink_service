import("//build/test.gni")
import("../../../../../nearlink_config.gni")
import("../../../../../test/utils/test_utils.gni")

config("nl_sl_host_service_unit_test_config") {
  include_dirs = [
    "$NEARLINK_ROOT/services/service/src/sl_host",
    "$NEARLINK_ROOT/services/service/src/base",
    "$NEARLINK_ROOT/services/service/src/adapter",
    "$NEARLINK_ROOT/test/unittest/mock",
    "$NEARLINK_ROOT/services/server/include",
    "$NEARLINK_ROOT/utils/include",
    "$NEARLINK_ROOT/interfaces/inner_api/include",
    "$NEARLINK_ROOT/services/service/src/cdsm",
  ]

  defines = [
    "private = public",
    "LOG_TAG = \"nearlink_test\"",
    "LOG_DOMAIN = 0xD000151",
  ]

  cflags_cc = [
    "-fexceptions",
    "-Wno-non-c-typedef-for-linkage",
    "-Wno-format",
  ]

  cflags = [ "--coverage" ]
  ldflags = [ "--coverage" ]
  visibility = [ ":*" ]
}

nl_sl_host_service_unit_test_deps = [
  "$NEARLINK_ROOT/ipc_parcel:nearlink_ipc_parcel",
  "$NEARLINK_ROOT/services/service:nearlink_service_impl",
  "$NEARLINK_ROOT/utils:nearlink_utils",
  "$NEARLINK_ROOT/services/server:nearlink_server_static",
  "$NEARLINK_ROOT/services/common:nearlink_service_common",
  "$NEARLINK_ROOT/services/device_manager:nearlink_device_manager",
  "$NEARLINK_ROOT/services/stack:nearlink_stack",
  "$NEARLINK_ROOT/services/stack/src/sdf:nearlink_stack_sdf",
  "$NEARLINK_ROOT/services/dft:nearlink_dft_manager",
  "${nearlink_test_utils_path}:test_utils_static",
]

nl_sl_host_service_unit_test_external_deps = [
  "googletest:gmock_main",
  "hilog:libhilog",
  "ffrt:libffrt",
  "access_token:libaccesstoken_sdk",
  "access_token:libtokenid_sdk",
  "huks:libhukssdk",
]

ohos_unittest("nl_sl_host_service_ut") {
  module_out_path = "nearlink_service/nearlink_service"
  branch_protector_ret = "pac_ret"

  sanitize = {
    cfi = true
    boundary_sanitize = true
    cfi_cross_dso = true
    integer_overflow = true
    ubsan = true
    debug = true
  }

  sources = [
    "$NEARLINK_ROOT/test/unittest/services_test/service_test/sl_host_test/sl_host_service_test.cpp",
    "$MOCK_HOST_SERVER_FILE_TDD/mock_nearlink_host_server.cpp",
  ]
  configs = [ ":nl_sl_host_service_unit_test_config" ]
  configs += [ "${nearlink_test_utils_path}:test_utils_config" ]
  deps = nl_sl_host_service_unit_test_deps
  external_deps = nl_sl_host_service_unit_test_external_deps

  part_name = "nearlink"
  subsystem_name = "communication"
}

group("nl_sl_host_service_unittest") {
  testonly = true
  deps = [ ":nl_sl_host_service_ut" ]
}