import("//build/ohos.gni")
import("//build/test.gni")
import("../../../../../nearlink_config.gni")
import("../../../../../test/utils/test_utils.gni")
NL_UNIT_TEST_DIR = "$NEARLINK_ROOT/test/unittest/services_test"

config("nl_asc_service_unit_test_config") {
  visibility = [ ":*" ]

  include_dirs = [
    "$NEARLINK_ROOT/services/common/include",
    "$NEARLINK_ROOT/services/service/src/util",
    "$NEARLINK_ROOT/services/service/src/adapter",
    "$NEARLINK_ROOT/services/service/src/common",
    "$NEARLINK_ROOT/services/service/src/base",
    "$NEARLINK_ROOT/services/server/include",
    "$NEARLINK_ROOT/services/ipc/include",
    "$NEARLINK_ROOT/services/service/src/asc",
    "$NEARLINK_ROOT/services/service/src/tws",
    "$NEARLINK_ROOT/services/service/src/cdsm/",
    "$NEARLINK_ROOT/services/dft/include/",
    "$NEARLINK_ROOT/services/service/src/dis/",
    "$NEARLINK_ROOT/services/service/src/datatransfer/",
    "$NEARLINK_ROOT/services/service/src/dialog/",
    "$NEARLINK_ROOT/services/hardware/include/",
    "$NEARLINK_ROOT/services/hardware/src",
    "$NEARLINK_ROOT/services/cloudpush/include/",
    "$NEARLINK_ROOT/services/service/src/adapter/highpower/",
    "$NEARLINK_ROOT/services/service/src/datashare/",
    "$NEARLINK_ROOT/services/hibox/include/",
    "$NEARLINK_ROOT/services/stack/src/cp/bal/audioctl/actm/include/inner",
    "$NEARLINK_ROOT/services/service/src/vcp/",
    "$NEARLINK_ROOT/services/service/src/vas/",
    "$NEARLINK_ROOT/services/service/src/mcp/",
    "$NEARLINK_ROOT/services/service/src/ccp/",
    "$NEARLINK_ROOT/services/service/src/mic/",
    "$NEARLINK_ROOT/services/device_manager/include",
    "$NEARLINK_ROOT/services/service/src/ServiceManagerPluginLoader",
    "$NEARLINK_ROOT/services/service/src/audio/",
    "$NEARLINK_ROOT/services/stack/include/ext",
  ]

  defines =  [
    "LOG_TAG = \"nearlink_test\"",
    "LOG_DOMAIN = 0xD000151",
    "private = public"
  ]
  cflags_cc = [ 
    "-fexceptions",
    "-fPIC",
    "-Wno-format",
    "-Wno-pessimizing-move",
    "-Wno-unused-parameter",
    "-Wreorder",
    "-Wmissing-braces",
    "-Wimplicit-fallthrough",
    "-Wlogical-op-parentheses",
    "-Wmissing-field-initializers",
    "-Wparentheses-equality",
    "-Wparentheses",
    "-Wdelete-non-abstract-non-virtual-dtor",
    "-Wignored-qualifiers",
    "-Wdelete-abstract-non-virtual-dtor",
    "-Wuninitialized",
    "-Woverloaded-virtual",
    "-Wdangling-else",
    "-Woverloaded-virtual",
    "-Wno-non-c-typedef-for-linkage",
    "-Wno-unused-but-set-variable",
    "-Wno-array-parameter",
    "-Wno-unused-lambda-capture",
    "-fdata-sections",
    "-ffunction-sections",
    "-fno-asynchronous-unwind-tables",
    "-fno-unwind-tables",
    "-Os",
  ]
  cflags = [ 
    "--coverage"
  ]
  ldflags = [ "--coverage" ]
}

unit_test_deps = [
  "$NEARLINK_ROOT/ipc_parcel:nearlink_ipc_parcel",
  "$NEARLINK_ROOT/utils:nearlink_utils",
  "$NEARLINK_ROOT/frameworks/native:nearlink_framework",
  "$NEARLINK_ROOT/services/common:nearlink_service_common",
  "$NEARLINK_ROOT/services/stack:nearlink_stack",
  "$NEARLINK_ROOT/services/server:nearlink_server_static",
  "$NEARLINK_ROOT/services/stack/src/sdf:nearlink_stack_sdf",
  "${nearlink_test_utils_path}:test_utils_static",
  "$NEARLINK_ROOT/services/hardware:nearlink_dli_adapter",
  "$NEARLINK_ROOT/services/service:nearlink_service_impl",
]

unit_test_external_deps = [
  "c_utils:utils",
  "hilog:libhilog",
  "safwk:system_ability_fwk",
  "samgr:samgr_proxy",
  "huks:libhukssdk",
  "ability_runtime:ability_manager",
  "preferences:native_preferences",
  "access_token:libaccesstoken_sdk",
  "access_token:libtokenid_sdk",
  "audio_framework:audio_policy_manager",
  "audio_framework:audio_engine_manager",
  "audio_framework:audio_foundation",
  "data_share:datashare_consumer",
  "ipc:ipc_core",
  "googletest:gmock",
]

test_out_path = "nearlink_service/nearlink_service"

ohos_unittest("nl_asc_service_test") {
  module_out_path = test_out_path

  branch_protector_ret = "pac_ret"  # Enable PAC CFI
  sanitize = {
    cfi = true                             # Enable/disable control flow integrity detection
    boundary_sanitize = true               # Enable boundary san detection
    cfi_cross_dso = true                   # Cross-SO CFI Checks
    integer_overflow = true                # Enable integer overflow detection
    ubsan = true                           # Enable some Ubsan options
    debug = true
  }

  sources = [
    "$NL_UNIT_TEST_DIR/service_test/asc_test/nearlink_asc_service_test.cpp",
    "$NL_UNIT_TEST_DIR/service_test/asc_test/mock_cdsm_service.cpp",
    "$NL_UNIT_TEST_DIR/service_test/asc_test/mock_sle_adapter.cpp",
    "$NL_UNIT_TEST_DIR/service_test/asc_test/mock_tws_service.cpp",
    "$NL_UNIT_TEST_DIR/service_test/asc_test/mock_audio_spatialization_manager.cpp",
  ]
  sources += [
    "$MOCK_HOST_SERVER_FILE_TDD/mock_nearlink_host_server.cpp",
    "$MOCK_HOST_SERVER_FILE_TDD/mock_nearlink_system_config.cpp"
  ]

  configs = [ ":nl_asc_service_unit_test_config" ]
  configs += ["${nearlink_test_utils_path}:test_utils_config"]

  deps = unit_test_deps

  external_deps = unit_test_external_deps
  external_deps += [
    "ffrt:libffrt",
    "hisysevent:libhisysevent",
    "hisysevent:libhisyseventmanager",
    "call_manager:tel_call_manager_api",
    "core_service:tel_core_service_api",
    "state_registry:tel_state_registry_api",
  ]

  part_name = "nearlink"
  subsystem_name = "communication"
}

group("nl_asc_service_unittest") {
  testonly = true
  deps = [
    ":nl_asc_service_test",
  ]
}
