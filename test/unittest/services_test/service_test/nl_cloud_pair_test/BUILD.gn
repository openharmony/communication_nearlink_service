import("//build/test.gni")
import("../../../../../nearlink_config.gni")
import("../../../../../test/utils/test_utils.gni")

config("nl_cloud_pair_service_unit_test_config") {
  visibility = [ ":*" ]

  include_dirs = [
    "$NEARLINK_ROOT/frameworks/native/include",
    "$NEARLINK_ROOT/utils/include",
    "$NEARLINK_ROOT/frameworks/common/ipc/parcel",
    "$NEARLINK_ROOT/services/server/include",
    "$NEARLINK_ROOT/services/ipc/include",
    "$NEARLINK_ROOT/services/hibox/include",
    "$NEARLINK_ROOT/interfaces/inner_api/include",
    "$NEARLINK_ROOT/services/service/include",
    "$NEARLINK_ROOT/services/common/include",
    "$NEARLINK_ROOT/services/service/src/adapter",
    "$NEARLINK_ROOT/services/service/src/cloudpair",
    "$NEARLINK_ROOT/services/service/src/datashare",
    "$NEARLINK_ROOT/services/service/src/common",
    "$NEARLINK_ROOT/services/service/src/base",
    "$NEARLINK_ROOT/services/service/src/util",
    "$NEARLINK_ROOT/services/service/src/scan",
    "$NEARLINK_ROOT/services/service/src/cdsm",
    "$NEARLINK_ROOT/services/service/src/tws",
    "$NEARLINK_ROOT/services/service/src/collaboration",
  ]

  defines =  [
    "LOG_TAG = \"nearlink_test\"",
    "LOG_DOMAIN = 0xD000151",
    "private = public",
  ]
  cflags_cc = [ "-fexceptions",
                "-Wno-non-c-typedef-for-linkage",
                "-Wno-format",
              ]
  cflags = [ "--coverage" ]
  ldflags = [ "--coverage" ]
}

unit_test_deps = [
  "$NEARLINK_ROOT/interfaces:nearlink_inner_api_headers",
  "$NEARLINK_ROOT/ipc_parcel:nearlink_ipc_parcel",
  "$NEARLINK_ROOT/services/ipc:nl_service_ipc",
  "$NEARLINK_ROOT/services/common:nearlink_service_common",
  "$NEARLINK_ROOT/services/device_manager:nearlink_device_manager",
  "$NEARLINK_ROOT/services/stack:nearlink_stack",
  "$NEARLINK_ROOT/services/stack/src/sdf:nearlink_stack_sdf",
  "$NEARLINK_ROOT/services/dft:nearlink_dft_manager",
  "${nearlink_test_utils_path}:test_utils_static",
]

unit_test_external_deps = [
    "ability_base:want",
    "ability_base:zuri",
    "ability_runtime:extension_manager",
    "access_token:libaccesstoken_sdk",
    "access_token:libtokenid_sdk",
    "access_token:libprivacy_sdk",
    "common_event_service:cesfwk_innerkits",
    "c_utils:utils",
    "cJSON:cjson",
    "ffrt:libffrt",
    "hilog:libhilog",
    "huks:libhukssdk",
    "init:libbegetutil",
    "init:libbeget_proxy",
    "ipc:ipc_core",
    "samgr:samgr_proxy",
    "data_share:datashare_common",
    "data_share:datashare_consumer",
    "ability_runtime:wantagent_innerkits",
    "time_service:time_client",
    "os_account:os_account_innerkits",
    "qos_manager:qos",
    "openssl:libcrypto_shared",
    "os_account:libaccountkits",
    "libxml2:libxml2",
    "hisysevent:libhisysevent",
    "hisysevent:libhisyseventmanager",
]

test_out_path = "nearlink_service/nearlink_service"

ohos_unittest("nl_cloud_pair_test") {
  module_out_path = test_out_path

  branch_protector_ret = "pac_ret"  # Enable PAC CFI
  sanitize = {
    cfi = true                             # Enable/disable control flow integrity detection
    boundary_sanitize = true               # Enable boundary san detection
    cfi_cross_dso = true                   # Cross-SO CFI Checks
    integer_overflow = true                # Enable integer overflow detection
    ubsan = true                           # Enable some Ubsan options
    debug = true
  }

  sources = [
    "$NEARLINK_ROOT/test/unittest/services_test/service_test/nl_cloud_pair_test/mock_sle_adapter.cpp",
    "$NEARLINK_ROOT/test/unittest/services_test/service_test/nl_cloud_pair_test/mock_sle_service_manager.cpp",
    "$NEARLINK_ROOT/test/unittest/services_test/service_test/nl_cloud_pair_test/mock_cdsm_service.cpp",
    "$NEARLINK_ROOT/test/unittest/services_test/service_test/nl_cloud_pair_test/mock_tws_service.cpp",
    "$NEARLINK_ROOT/test/unittest/services_test/service_test/nl_cloud_pair_test/sle_cloud_pair_service_test.cpp",
    "$NEARLINK_ROOT/test/unittest/mock/mock_sle_remote_device_adapter.cpp",

    "$NEARLINK_ROOT/services/service/src/cloudpair/SleCloudPairService.cpp",
    "$NEARLINK_ROOT/services/common/src/nearlink_common_event_helper.cpp",
    "$NEARLINK_ROOT/services/service/src/common/ClassCreator.cpp",
  ]

  configs = [ ":nl_cloud_pair_service_unit_test_config" ]
  configs += ["${nearlink_test_utils_path}:test_utils_config"]

  deps = unit_test_deps

  external_deps = unit_test_external_deps
  external_deps += [ "ffrt:libffrt" ]

  part_name = "nearlink"
  subsystem_name = "communication"
}

group("nl_cloud_pair_unittest") {
  testonly = true
  deps = [
    ":nl_cloud_pair_test",
  ]
}