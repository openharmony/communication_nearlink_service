import("//build/test.gni")
import("../../../../../nearlink_config.gni")
import("../../../../../test/utils/test_utils.gni")

config("nl_datatransfer_service_unit_test_config") {
  visibility = [ ":*" ]

  include_dirs = [
    "$NEARLINK_ROOT/services/common/include",
    "$NEARLINK_ROOT/services/service/src/util",
    "$NEARLINK_ROOT/services/service/src/adapter",
    "$NEARLINK_ROOT/services/service/src/datatransfer",
    "$NEARLINK_ROOT/services/service/src/icce",
    "$NEARLINK_ROOT/services/service/src/cdsm",
    "$NEARLINK_ROOT/services/service/src/port",
    "$NEARLINK_ROOT/services/service/src/common",
    "$NEARLINK_ROOT/services/service/src/base",
    "$NEARLINK_ROOT/services/server/include",
    "$NEARLINK_ROOT/services/ipc/include",
    "$NEARLINK_ROOT/services/dft/include",
    "$NEARLINK_ROOT/services/stack/src/cp/bal/profile/port",
  ]

  defines =  [
    "LOG_TAG = \"nearlink_test\"",
    "LOG_DOMAIN = 0xD000151",
    "private = public"
  ]
  cflags_cc = [ "-fexceptions" ]
  cflags = [ "--coverage" ]
  ldflags = [ "--coverage" ]
}

unit_test_deps = [
  "$NEARLINK_ROOT/ipc_parcel:nearlink_ipc_parcel",
  "$NEARLINK_ROOT/socket:nearlink_socket",
  "$NEARLINK_ROOT/utils:nearlink_utils",
  "$NEARLINK_ROOT/frameworks/native:nearlink_framework",
  "$NEARLINK_ROOT/services/common:nearlink_service_common",
  "$NEARLINK_ROOT/services/device_manager:nearlink_device_manager",
  "$NEARLINK_ROOT/services/service:nearlink_service_impl",
  "$NEARLINK_ROOT/services/stack:nearlink_stack",
  "$NEARLINK_ROOT/services/stack/src/sdf:nearlink_stack_sdf",
  "$NEARLINK_ROOT/services/server:nearlink_server_static",
  "${nearlink_test_utils_path}:test_utils_static",
]

unit_test_external_deps = [
  "c_utils:utils",
  "hilog:libhilog",
  "safwk:system_ability_fwk",
  "samgr:samgr_proxy",
  "huks:libhukssdk",
  "init:libbegetutil",
  "preferences:native_preferences",
  "access_token:libaccesstoken_sdk",
  "access_token:libtokenid_sdk",
]

test_out_path = "nearlink_service/nearlink_service"

ohos_unittest("nl_datatransfer_test") {
  module_out_path = test_out_path

  branch_protector_ret = "pac_ret"  # Enable PAC CFI
  sanitize = {
    cfi = true                             # Enable/disable control flow integrity detection
    boundary_sanitize = true               # Enable boundary san detection
    cfi_cross_dso = true                   # Cross-SO CFI Checks
    integer_overflow = true                # Enable integer overflow detection
    ubsan = true                           # Enable some Ubsan options
    debug = true
  }

  sources = [
      "$NEARLINK_ROOT/test/unittest/services_test/service_test/nl_datatransfer_test/nearlink_datatransfer_test.cpp",
      "$NEARLINK_ROOT/test/unittest/services_test/service_test/nl_datatransfer_test/mock_sle_adapter.cpp",
      "$NEARLINK_ROOT/test/unittest/services_test/service_test/nl_datatransfer_test/mock_sle_service_manager.cpp",
      "$NEARLINK_ROOT/test/unittest/services_test/service_test/nl_datatransfer_test/mock_icce_service.cpp",
      "$NEARLINK_ROOT/test/unittest/services_test/service_test/nl_datatransfer_test/mock_nlstk_port_client.cpp",
      "$NEARLINK_ROOT/test/unittest/services_test/service_test/nl_datatransfer_test/mock_nlstk_port_server.cpp",
      "$NEARLINK_ROOT/test/unittest/services_test/service_test/nl_datatransfer_test/mock_profile_service_manager.cpp",

      "$NEARLINK_ROOT/services/service/src/port/PortService.cpp",
      "$NEARLINK_ROOT/services/service/src/port/PortClientStackAdapter.cpp",
      "$NEARLINK_ROOT/services/service/src/port/PortServerStackAdapter.cpp",
      "$NEARLINK_ROOT/test/unittest/services_test/service_test/nl_datatransfer_test/nearlink_port_service_test.cpp",
    ]

  configs = [ ":nl_datatransfer_service_unit_test_config" ]
  configs += ["${nearlink_test_utils_path}:test_utils_config"]

  deps = unit_test_deps

  external_deps = unit_test_external_deps
  external_deps += [
    "ffrt:libffrt",
    "hisysevent:libhisysevent",
    "hisysevent:libhisyseventmanager",
  ]

  part_name = "nearlink"
  subsystem_name = "communication"
}

group("nl_datatransfer_unittest") {
  testonly = true
  deps = [
    ":nl_datatransfer_test",
  ]
}