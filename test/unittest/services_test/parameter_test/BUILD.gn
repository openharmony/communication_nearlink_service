import("//build/test.gni")
import("../../../../nearlink_config.gni")

config("nearlink_parameter_test_config") {
  visibility = [ ":*" ]

  include_dirs = [
    "$NEARLINK_ROOT/services/common/include",
    "$NEARLINK_ROOT/services/common/src",
  ]

  defines = [
    "LOG_TAG = \"nearlink_test\"",
    "LOG_DOMAIN = 0xD000151",
  ]
  cflags_cc = [ "-fexceptions" ]
  cflags = [ "--coverage" ]
  ldflags = [ "--coverage" ]
}

ohos_unittest("nearlink_parameter_test") {
  module_out_path = "nearlink_service/nearlink_service"

  branch_protector_ret = "pac_ret"
  sanitize = {
    cfi = true
    boundary_sanitize = true
    cfi_cross_dso = true
    integer_overflow = true
    ubsan = true
    debug = false
  }

  sources = [
    "parameter_test.cpp",
  ]

  configs = [ ":nearlink_parameter_test_config" ]

  deps = [
    "$NEARLINK_ROOT/services/common:nearlink_service_common",
  ]

  external_deps = [
    "c_utils:utils",
    "hilog:libhilog",
    "googletest:gtest_main",
  ]

  part_name = "nearlink_service"
  subsystem_name = "communication"
}

group("nearlink_parameter_unittest") {
  testonly = true
  deps = [
    ":nearlink_parameter_test",
  ]
}