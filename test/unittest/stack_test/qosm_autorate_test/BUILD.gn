import("//build/test.gni")
import("../../../../nearlink_config.gni")
import("../../../../test/utils/test_utils.gni")
import("../../../../test/utils/stack_tdd.gni")
NEW_STACK_DIR = "$NEARLINK_ROOT/services/stack/src"

config("stack_unit_test_config") {
  visibility = [ ":*" ]

  include_dirs = shared_stack_include_dirs + [
    "$NEARLINK_ROOT/test/unittest/stack_test/qosm_autorate_test/"
  ]

  defines =  [
    "LOG_TAG = \"nearlink_test\"",
    "LOG_DOMAIN = 0xD000151",
  ]
  cflags_cc = [ "-fexceptions" ]
  cflags = [ "--coverage" ]
  ldflags = [ "--coverage" ]
  cflags += [ "-DNEARLINK_SERVICE_STACK_LOCAL_TEST" ]
}

unit_test_deps = [
  "$NEARLINK_ROOT/services/dft:nearlink_dft_manager",
]

unit_test_external_deps = [
  "c_utils:utils",
  "hilog:libhilog",
  "googletest:gtest_main",
  "googletest:gmock_main",
  "hisysevent:libhisysevent",
  "hisysevent:libhisyseventmanager",
]

test_out_path = "nearlink_service/nearlink_service"

ohos_unittest("nl_stack_qosm_audio_dfx_test") {
  module_out_path = test_out_path

  branch_protector_ret = "pac_ret"  # Enable PAC CFI
  sanitize = {
    cfi = true                             # Enable/disable control flow integrity detection
    boundary_sanitize = true               # Enable boundary san detection
    cfi_cross_dso = true                   # Cross-SO CFI Checks
    integer_overflow = true                # Enable integer overflow detection
    ubsan = true                           # Enable some Ubsan options
    debug = false
  }

  sources = [
    "$NEW_STACK_DIR/sdf/bsl/dsl/src/sdf_dlist.c",
    "$NEW_STACK_DIR/sdf/dfx/log/src/sdf_log_api.c",
    "$NEW_STACK_DIR/sdf/oal/memm/src/sdf_mem.c",
    "$NEW_STACK_DIR/sdf/utils/src/sdf_addr.c",
    "$NEW_STACK_DIR/cp/bsl/sle/qosm/autorate/src/qosm_audio_dfx.c",
    "$NEW_STACK_DIR/cp/bsl/sle/qosm/autorate/src/qosm_antenna_dfx.c",
    "$NEW_STACK_DIR/adapter/src/dli_reg_ext_func.c",
    "$NEW_STACK_DIR/adapter/src/common_ext_func_wrapper.c",
    "$NEW_STACK_DIR/adapter/src/common_reg_ext_func.c",
    "$NEW_STACK_DIR/adapter/src/qosm_ext_func_wrapper.c",
    "$NEW_STACK_DIR/adapter/src/qosm_reg_ext_func.c",

    "qosm_autorate_test_log.cpp",
    "qosm_audio_dfx_test.cpp",
  ]

  defines =  [
    "UT_TEST = 1",
  ]

  configs = [ ":stack_unit_test_config" ]
  configs += ["${nearlink_test_utils_path}:test_utils_config"]

  deps = unit_test_deps
  external_deps = unit_test_external_deps

  part_name = "nearlink"
  subsystem_name = "communication"
}

