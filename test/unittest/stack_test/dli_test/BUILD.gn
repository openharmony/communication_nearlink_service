    "$NEARLINK_ROOT/services/hardware/src/SleDliLayerAdapter.cpp",
    "$NEARLINK_ROOT/services/hardware/src/SleDliCallbacks.cpp",
    "$NEARLINK_ROOT/services/hardware/src/SleDliSnoop.cpp",
    "$NEARLINK_ROOT/services/hardware/src/SleDliThreadUtil.cpp",
    "$NEARLINK_ROOT/test/unittest/stack_test/stack_mock/stack_schedule_mock.cpp",
    "$NEARLINK_ROOT/test/unittest/stack_test/stack_mock/stack_schedule_stub.c",
    "$NEARLINK_ROOT/test/unittest/stack_test/stack_mock/stack_dli_stub.c",
    "dli_test.cpp",
    "ut_dli_event.cpp",
    "ut_dli_test.cpp",
  ]

  configs = [ ":stack_unit_test_config" ]
  configs += ["${nearlink_test_utils_path}:test_utils_config"]

  deps = unit_test_deps

  external_deps = unit_test_external_deps
  external_deps += [ "ffrt:libffrt" ]

  part_name = "nearlink"
  subsystem_name = "communication"
}

group("nl_stack_dli_unittest") {
  testonly = true
  deps = [
    ":dli_test",
  ]
}