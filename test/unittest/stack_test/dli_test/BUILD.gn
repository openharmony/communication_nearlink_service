import("//build/test.gni")
import("../../../../nearlink_config.gni")
import("../../../../test/utils/test_utils.gni")
import("../../../utils/stack_tdd.gni")

config("stack_unit_test_config") {
  visibility = [ ":*" ]

  include_dirs = shared_stack_include_dirs + [
    "$NEARLINK_ROOT/test/unittest/stack_test/stack_mock/",
  ]

  defines =  [
    "LOG_TAG = \"nearlink_test\"",
    "LOG_DOMAIN = 0xD000151",
  ]
  cflags_cc = [ "-fexceptions" ]
  cflags = [ "--coverage" ]
  ldflags = [ "--coverage" ]
}

unit_test_deps = [
  "$NEARLINK_ROOT/services/dft:nearlink_dft_manager",
]

unit_test_external_deps = [
  "c_utils:utils",
  "hilog:libhilog",
  "drivers_interface_nearlink:libnearlink_hci_proxy_1.0",
  "drivers_interface_nearlink:libnearlink_hci_proxy_1.1",
  "openssl:libcrypto_shared",
  "init:libbegetutil",
  "googletest:gtest_main",
  "googletest:gmock_main",
  "hisysevent:libhisysevent",
  "hisysevent:libhisyseventmanager",
]

test_out_path = "nearlink_service/nearlink_service"

ohos_unittest("dli_test") {
  module_out_path = test_out_path

  branch_protector_ret = "pac_ret"  # Enable PAC CFI
  sanitize = {
    cfi = true                             # Enable/disable control flow integrity detection
    boundary_sanitize = true               # Enable boundary san detection
    cfi_cross_dso = true                   # Cross-SO CFI Checks
    integer_overflow = true                # Enable integer overflow detection
    ubsan = true                           # Enable some Ubsan options
    debug = false
  }

  sources = [
    "$NEARLINK_ROOT/services/stack/src/dli/dli.c",
    "$NEARLINK_ROOT/services/stack/src/dli/cmd/src/dli_cmd.c",
    "$NEARLINK_ROOT/services/stack/src/dli/event/src/dli_event.c",
    "$NEARLINK_ROOT/services/stack/src/dli/event/src/dli_connect_event.c",
    "$NEARLINK_ROOT/services/stack/src/dli/event/src/dli_dev_discovery_event.c",
    "$NEARLINK_ROOT/services/stack/src/dli/event/src/dli_hadm_event.c",
    "$NEARLINK_ROOT/services/stack/src/dli/event/src/dli_secu_event.c",
    "$NEARLINK_ROOT/services/stack/src/dli/event/src/dli_factory_event.c",
    "$NEARLINK_ROOT/services/stack/src/dli/event/src/dli_nbc_event.c",
    "$NEARLINK_ROOT/services/stack/src/dli/layer/src/dli_layer_callback.c",
    "$NEARLINK_ROOT/services/stack/src/dli/layer/src/dli_layer_config.c",
    "$NEARLINK_ROOT/services/stack/src/dli/layer/src/dli_layer_utils.c",
    "$NEARLINK_ROOT/services/stack/src/dli/layer/src/dli_layer.c",
    "$NEARLINK_ROOT/services/stack/src/dli/thread/src/dli_thread.c",
    "$NEARLINK_ROOT/services/stack/src/dli/sapi/src/dli_sapi.c",
    "$NEARLINK_ROOT/services/stack/src/adapter/src/collab_ext_func_wrapper.c",
