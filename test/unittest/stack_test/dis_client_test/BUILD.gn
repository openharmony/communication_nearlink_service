import("//build/test.gni")
import("../../../../nearlink_config.gni")
import("../../../../test/utils/test_utils.gni")
import("../../../utils/stack_tdd.gni")

config("stack_unit_test_config") {
  visibility = [ ":*" ]

  include_dirs = shared_stack_include_dirs + [
    "$NEARLINK_ROOT/test/unittest/stack_test/stack_mock/",
    "$NEARLINK_ROOT/services/stack/src/cp/bal/profile/bas/src/bas_client.h",
  ]

  defines =  [
    "LOG_TAG = \"nearlink_test\"",
    "LOG_DOMAIN = 0xD000151",
  ]
  cflags_cc = [ "-fexceptions" ]
  cflags = [ "--coverage" ]
  ldflags = [ "--coverage" ]
}

unit_test_deps = [
  "$NEARLINK_ROOT/services/dft:nearlink_dft_manager",
]

unit_test_external_deps = [
  "c_utils:utils",
  "hilog:libhilog",
  "drivers_interface_nearlink:libnearlink_hci_proxy_1.0",
  "drivers_interface_nearlink:libnearlink_hci_proxy_1.1",
  "openssl:libcrypto_shared",
  "init:libbegetutil",
  "googletest:gtest_main",
  "googletest:gmock_main",
  "hisysevent:libhisysevent",
  "hisysevent:libhisyseventmanager",
]

test_out_path = "nearlink_service/nearlink_service"

ohos_unittest("nl_stack_dis_client_test") {
  module_out_path = test_out_path

  branch_protector_ret = "pac_ret"  # Enable PAC CFI
  sanitize = {
    cfi = true                             # Enable/disable control flow integrity detection
    boundary_sanitize = true               # Enable boundary san detection
    cfi_cross_dso = true                   # Cross-SO CFI Checks
    integer_overflow = true                # Enable integer overflow detection
    ubsan = true                           # Enable some Ubsan options
    debug = false
  }

  sources = []
  foreach(s, shared_stack_source) {
    if (s != "$STACK_DIR/src/dp/dtap/src/dtap.c" &&
      s != "$STACK_DIR/src/cp/bsl/sle/cm/link/src/cm_api.c" &&
      s != "$STACK_DIR/src/cp/nlstkfwk/schedule/src/nlstk_schedule.c") {
      sources += [ s ]
    }
  }
  sources += [
    "dis_client_test.cpp",
    "$NEARLINK_ROOT/test/unittest/stack_test/stack_mock/stack_schedule_mock.cpp",
    "$NEARLINK_ROOT/test/unittest/stack_test/stack_mock/stack_schedule_stub.c",
    "$NEARLINK_ROOT/test/unittest/stack_test/stack_mock/stack_cm_mock.cpp",
    "$NEARLINK_ROOT/test/unittest/stack_test/stack_mock/stack_cm_stub.c",
    "$NEARLINK_ROOT/test/unittest/stack_test/stack_mock/stack_dtap_mock.cpp",
    "$NEARLINK_ROOT/test/unittest/stack_test/stack_mock/stack_dtap_stub.c",
  ]

  configs = [ ":stack_unit_test_config" ]
  configs += ["${nearlink_test_utils_path}:test_utils_config"]

  deps = unit_test_deps
  external_deps = unit_test_external_deps
  external_deps += [ "ffrt:libffrt" ]

  part_name = "nearlink"
  subsystem_name = "communication"
}

group("nl_stack_dis_client_unittest") {
  testonly = true
  deps = [
    ":nl_stack_dis_client_test",
  ]
}