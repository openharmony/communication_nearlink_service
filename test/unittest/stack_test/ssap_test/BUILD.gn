import("//build/test.gni")
import("../../../../nearlink_config.gni")
import("../../../../test/utils/test_utils.gni")
import("../../../../test/utils/stack_tdd.gni")
#NEW_STACK_DIR = "$NEARLINK_ROOT/services/stack/src"
STACK_DIR = "$NEARLINK_ROOT/services/stack"

config("stack_unit_test_config") {
  visibility = [ ":*" ]

  include_dirs = shared_stack_include_dirs + [
    "$NEARLINK_ROOT/test/unittest/stack_test/stack_mock/",
  ]

  defines =  [
    "LOG_TAG = \"nearlink_test\"",
    "LOG_DOMAIN = 0xD000151",
  ]
  cflags_cc = [ "-fexceptions" ]
  cflags = [ "--coverage" ]
  ldflags = [ "--coverage" ]
}

unit_test_deps = [
  "$NEARLINK_ROOT/services/dft:nearlink_dft_manager",
]

unit_test_external_deps = [
  "c_utils:utils",
  "hilog:libhilog",
  "drivers_interface_nearlink:libnearlink_hci_proxy_1.0",
  "drivers_interface_nearlink:libnearlink_hci_proxy_1.1",
  "hdf_core:libhdf_utils",
  "openssl:libcrypto_shared",
  "init:libbegetutil",
  "googletest:gtest_main",
  "googletest:gmock_main",
  "hisysevent:libhisysevent",
  "hisysevent:libhisyseventmanager",
]

test_out_path = "nearlink_service/nearlink_service"

ohos_unittest("nl_stack_ssap_test") {
  module_out_path = test_out_path

  branch_protector_ret = "pac_ret"  # Enable PAC CFI
  sanitize = share_sanitize

  sources = []
  foreach(s, shared_stack_source) {
    if (s != "$STACK_DIR/src/sdf/bsl/dsl/src/sdf_vector.c" &&
        s != "$STACK_DIR/src/cp/bsl/sle/servm/ssap/src/ssap_link_state.c" &&
        s != "$STACK_DIR/src/cp/bsl/sle/servm/ssap/src/ssap_handle.c" &&
        s != "$STACK_DIR/src/cp/bsl/sle/servm/ssap/src/ssap_manager.c" &&
        s != "$STACK_DIR/src/cp/bsl/sle/servm/ssap/src/ssap_utils.c" &&
        s != "$STACK_DIR/src/cp/bsl/sle/servm/ssap/src/ssapc_app_link_sm.c") {
      sources += [ s ]
    }
  }

  sources += [
    "ssap_test.cpp",
    "$NEARLINK_ROOT/test/unittest/stack_test/stack_mock/stack_ssap_mock.cpp",
    "$NEARLINK_ROOT/test/unittest/stack_test/stack_mock/stack_ssap_stub.c",
  ]

  configs = [ ":stack_unit_test_config" ]
  configs += ["${nearlink_test_utils_path}:test_utils_config"]

  deps = unit_test_deps
  external_deps = unit_test_external_deps
  external_deps += [ "ffrt:libffrt" ]

  part_name = "nearlink"
  subsystem_name = "communication"
}

group("nl_stack_ssap_unittest") {
  testonly = true
  deps = [
    ":nl_stack_ssap_test",
  ]
}
