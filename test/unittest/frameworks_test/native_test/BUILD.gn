import("//build/test.gni")
import("../../../../nearlink_config.gni")
import("../../../../test/utils/test_utils.gni")

NL_UNIT_TEST_DIR = "$NEARLINK_ROOT/test/unittest/frameworks_test"

config("native_unit_test_config") {
  visibility = [ ":*" ]

  include_dirs = [
    "$NEARLINK_ROOT/frameworks/native/include",
    "$NEARLINK_ROOT/frameworks/native",
    "$NEARLINK_ROOT/frameworks/ipc/include",
    "$NEARLINK_ROOT/interfaces/inner_api/include",
    "$NEARLINK_ROOT/services/ipc/include",
    "$NEARLINK_ROOT/services/ipc/src",
    "$NEARLINK_ROOT/services/common/include",
    "$NEARLINK_ROOT/services/server/include",
    "$NEARLINK_ROOT/services/service/src/tws",
    "$NEARLINK_ROOT/services/service/src/util",
    "$NEARLINK_ROOT/services/service/src/base",
    "$NEARLINK_ROOT/services/stack/src/sdf/interface",
    "$NEARLINK_ROOT/services/stack/src/nai/api/include/common",
    "$NEARLINK_ROOT/services/stack/include/ext",
    "$NEARLINK_ROOT/frameworks/ranging_alogorithm_adapter/include",
    "$NEARLINK_ROOT/frameworks/ranging_alogorithm_adapter/src",
  ]

  defines =  [
    "LOG_TAG = \"nearlink_test\"",
    "LOG_DOMAIN = 0xD000151",
    "private = public",
    "protected = public",
  ]
  cflags_cc = [ "-fexceptions" ]
  cflags = [ "--coverage" ]
  ldflags = [ "--coverage" ]
}

unit_test_deps = [
  "$NEARLINK_ROOT/ipc_parcel:nearlink_ipc_parcel",
  "$NEARLINK_ROOT/socket:nearlink_socket",
  "$NEARLINK_ROOT/utils:nearlink_utils",
  "$NEARLINK_ROOT/frameworks/native:nearlink_framework",
  "$NEARLINK_ROOT/services/ipc:nl_service_ipc",
  "$NEARLINK_ROOT/services/server:nearlink_server",
  "$NEARLINK_ROOT/services/common:nearlink_service_common",
  "$NEARLINK_ROOT/services/device_manager:nearlink_device_manager",
  "$NEARLINK_ROOT/services/service:nearlink_service_impl",
  "${nearlink_test_utils_path}:test_utils_static",
]

unit_test_external_deps = [
  "c_utils:utils",
  "hilog:libhilog",
  "ipc:ipc_core",
  "safwk:system_ability_fwk",
  "samgr:samgr_proxy",
  "init:libbegetutil",
  "googletest:gmock_main",
  "ffrt:libffrt",
]

test_out_path = "nearlink_service/nearlink_service"

ohos_unittest("nl_native_test") {
  module_out_path = test_out_path

  branch_protector_ret = "pac_ret"  # Enable PAC CFI
  sanitize = {
    cfi = true                             # Enable/disable control flow integrity detection
    boundary_sanitize = true               # Enable boundary san detection
    cfi_cross_dso = true                   # Cross-SO CFI Checks
    integer_overflow = true                # Enable integer overflow detection
    ubsan = true                           # Enable some Ubsan options
    debug = false
  }

  sources = [
    "$NL_UNIT_TEST_DIR/native_test/nearlink_host_test.cpp",
    "$NL_UNIT_TEST_DIR/native_test/nearlink_switch_module_test.cpp",
    "$NL_UNIT_TEST_DIR/native_test/nearlink_sa_manager_test.cpp",
    "$NL_UNIT_TEST_DIR/native_test/nearlink_sle_advertiser_test.cpp",
    "$NL_UNIT_TEST_DIR/native_test/nearlink_sle_scanner_test.cpp",
    "$NL_UNIT_TEST_DIR/native_test/nearlink_remote_device_test.cpp",
    "$NL_UNIT_TEST_DIR/native_test/nearlink_ssap_server_test.cpp",
    "$NL_UNIT_TEST_DIR/native_test/nearlink_tws_client_test.cpp",
    "$NL_UNIT_TEST_DIR/native_test/nearlink_cdsm_client_test.cpp",
    "$NL_UNIT_TEST_DIR/native_test/nearlink_sle_ranging_test.cpp",
    "$NL_UNIT_TEST_DIR/native_test/nearlink_sle_datatransfer_test.cpp",
    "$NL_UNIT_TEST_DIR/native_test/nearlink_sle_hadm_callback_test.cpp",
    "$NL_UNIT_TEST_DIR/native_test/nearlink_sle_controller_test.cpp",
    "$NL_UNIT_TEST_DIR/native_test/nearlink_hid_host_test.cpp",
    "$NL_UNIT_TEST_DIR/native_test/nearlink_vcp_client_test.cpp",
    "$NL_UNIT_TEST_DIR/native_test/nearlink_sle_audiostream_test.cpp",
  ]

  configs = [ ":native_unit_test_config" ]
  configs += ["${nearlink_test_utils_path}:test_utils_config"]

  deps = unit_test_deps

  external_deps = unit_test_external_deps

  part_name = "nearlink"
  subsystem_name = "communication"
}

group("nl_native_unittest") {
  testonly = true
  deps = [
    ":nl_native_test",
    "nearlink_ssap_client_test:nl_native_ssap_client_unittest",
  ]
}
