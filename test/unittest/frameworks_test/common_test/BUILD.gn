import("//build/test.gni")
import("../../../../nearlink_config.gni")
import("../../../../test/utils/test_utils.gni")
NL_UNIT_TEST_DIR = "$NEARLINK_ROOT/test/unittest/frameworks_test"

config("common_test_config") {
  visibility = [ ":*" ]

  include_dirs = [
    "$NEARLINK_ROOT/utils/include",
    "$NEARLINK_ROOT/utils/src",
    "$NEARLINK_ROOT/interfaces/inner_api/include",
  ]

  defines =  [
    "LOG_TAG = \"nearlink_test\"",
    "LOG_DOMAIN = 0xD000151",
    "private = public",
    "protected = public",
  ]
  cflags_cc = [ "-fexceptions" ]
  cflags = [ "--coverage" ]
  ldflags = [ "--coverage" ]
}

unit_test_deps = [
  "$NEARLINK_ROOT/utils:nearlink_utils",
  "$NEARLINK_ROOT/socket:nearlink_socket",
  "${nearlink_test_utils_path}:test_utils_static",
]

unit_test_external_deps = [
  "c_utils:utils",
  "hilog:libhilog",
  "ffrt:libffrt",
  "googletest:gtest_main",
]

test_out_path = "nearlink_service/nearlink_service"

ohos_unittest("nl_common_test") {
  module_out_path = test_out_path

  branch_protector_ret = "pac_ret"  # Enable PAC CFI
  sanitize = {
      cfi = true                             # Enable/disable control flow integrity detection
      boundary_sanitize = true               # Enable boundary san detection
      cfi_cross_dso = true                   # Cross-SO CFI Checks
      integer_overflow = true                # Enable integer overflow detection
      ubsan = true                           # Enable some Ubsan options
      debug = false
  }

  sources = [
    "$NL_UNIT_TEST_DIR/common_test/sle_service_data_test.cpp",
    "$NL_UNIT_TEST_DIR/common_test/nearlink_safe_weak_list_test.cpp",
    "$NL_UNIT_TEST_DIR/common_test/nearlink_safe_list_test.cpp",
    "$NL_UNIT_TEST_DIR/common_test/nearlink_safe_map_test.cpp",
    "$NL_UNIT_TEST_DIR/common_test/nearlink_safe_set_test.cpp",
    "$NL_UNIT_TEST_DIR/common_test/nearlink_safe_hashmap_test.cpp",
    "$NL_UNIT_TEST_DIR/common_test/nearlink_datatransfer_parcel_test.cpp",
    "$NL_UNIT_TEST_DIR/common_test/nearlink_socket_manager_test.cpp",
    "$NL_UNIT_TEST_DIR/common_test/nearlink_utils_test.cpp",
  ]

  configs = [ ":common_test_config" ]
  configs += ["${nearlink_test_utils_path}:test_utils_config"]

  deps = unit_test_deps

  external_deps = unit_test_external_deps

  part_name = "nearlink"
  subsystem_name = "communication"
}

group("nl_common_unittest") {
  testonly = true
  deps = [
    ":nl_common_test",
  ]
}
