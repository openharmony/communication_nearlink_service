#####################hydra-fuzz###################
import("//build/config/features.gni")
import("//build/test.gni")
import("../../../../nearlink_config.gni")
import("../../../utils/test_utils.gni")

##############################fuzztest##########################################
ohos_fuzztest("DataTransferServiceFuzzTest") {
  module_out_path = module_output_path
  fuzz_config_file = "$NEARLINK_ROOT/test/fuzztest/datatransfer_fuzzer/datatransferservice_fuzzer"

  defines = ["private = public"]
  cflags = [
    "-g",
    "-O0",
    "-Wno-unused-variable",
    "-fno-omit-frame-pointer",
  ]

  branch_protector_ret = "pac_ret"
  sanitize = {
    cfi = true                             # Enable/disable control flow integrity detection
    cfi_cross_dso = true                   # Cross-SO CFI Checks
    debug = true
  }

  include_dirs = [
    "$NEARLINK_ROOT/services/service/src/permission",
    "$NEARLINK_ROOT/services/service/src/util",
    "$NEARLINK_ROOT/services/service/src/adapter",
    "$NEARLINK_ROOT/services/service/src/datatransfer",
    "$NEARLINK_ROOT/services/service/src/icce",
    "$NEARLINK_ROOT/services/service/src/cdsm",
    "$NEARLINK_ROOT/services/service/src/port",
    "$NEARLINK_ROOT/services/service/src/common",
    "$NEARLINK_ROOT/services/service/src/base",
    "$NEARLINK_ROOT/services/server/include",
    "$NEARLINK_ROOT/services/ipc/include",
    "$NEARLINK_ROOT/services/dft/include",
    "$NEARLINK_ROOT/services/stack/src/cp/bal/profile/port",
  ]

  configs = [ "${nearlink_test_utils_path}:test_utils_config" ]
  configs += [ "${nearlink_fuzztest_utils_path}:fuzztest_utils_config" ]

  sources = ["datatransferservice_fuzzer.cpp"]
  sources += [ "$MOCK_HOST_SERVER_FILE/mock_nearlink_host_server.cpp" ]

  deps = [
    "$NEARLINK_ROOT/frameworks/native:nearlink_framework",
    "$NEARLINK_ROOT/utils:nearlink_utils",
    "$NEARLINK_ROOT/ipc_parcel:nearlink_ipc_parcel",
    "$NEARLINK_ROOT/socket:nearlink_socket",
    "$NEARLINK_ROOT/services/ipc:nl_service_ipc",
    "$NEARLINK_ROOT/services/common:nearlink_service_common",
    "$NEARLINK_ROOT/services/device_manager:nearlink_device_manager",
    "$NEARLINK_ROOT/services/server:nearlink_server_static",
    "$NEARLINK_ROOT/services/service:nearlink_service_impl",
    "$NEARLINK_ROOT/services/stack:nearlink_stack",
    "$NEARLINK_ROOT/services/stack/src/sdf:nearlink_stack_sdf",
    "${nearlink_test_utils_path}:test_utils_static",
    "${nearlink_fuzztest_utils_path}:fuzztest_utils_static"
  ]

  external_deps = [
    "c_utils:utils",
    "hilog:libhilog",
    "safwk:system_ability_fwk",
    "samgr:samgr_proxy",
    "huks:libhukssdk",
    "init:libbegetutil",
    "preferences:native_preferences",
    "access_token:libaccesstoken_sdk",
    "access_token:libtokenid_sdk",
  ]
  external_deps += [
    "ffrt:libffrt",
    "hisysevent:libhisysevent",
    "hisysevent:libhisyseventmanager",
  ]
}

###############################################################################
group("fuzztest") {
  testonly = true
  deps = []
  deps += [
    # deps file
    ":DataTransferServiceFuzzTest",
  ]
}
###############################################################################