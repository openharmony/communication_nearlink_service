#####################hydra-fuzz###################
import("//build/ohos.gni")
import("//build/ohos_var.gni")

import("//build/config/features.gni")
import("//build/test.gni")
import("../../../../nearlink_config.gni")
import("../../../../test/utils/test_utils.gni")
import("../../../../test/utils/stack_fuzz.gni")

##############################fuzztest##########################################
ohos_fuzztest("UapiGleFuzzTest") {
  module_out_path = module_output_path
  fuzz_config_file = "$NEARLINK_ROOT/test/fuzztest/stack_fuzzer/uapigle_fuzzer"
  include_dirs = shared_stack_include_dirs
  cflags = [
    "-g",
    "-O0",
    "-Wno-unused-variable",
    "-fno-omit-frame-pointer",
    ]
  cflags_cc = [
    "-fstack-protector-all",
    "-Wno-implicit-fallthrough",
    "-D_POSIX_C_SOURCE=200112L",
    "-D_GNU_SOURCE",
    "-DNEARLINK_SERVICE_STACK_LOCAL_TEST",
  ]
  sources = shared_stack_source + [
    "uapigle_fuzzer.cpp",
  ]

  deps = [ 
          "$NEARLINK_ROOT/services/hardware:nearlink_dli_adapter",
          "$NEARLINK_ROOT/utils:nearlink_utils",
          "$NEARLINK_ROOT/services/dft:nearlink_dft_manager",
  ]
  external_deps = [
    "c_utils:utils",
    "hilog:libhilog",
    "openssl:libcrypto_shared",
    "init:libbegetutil",
    "hisysevent:libhisysevent",
    "hisysevent:libhisyseventmanager",
  ]
}
###############################################################################
group("fuzztest") {
  testonly = true
  deps = []
  deps += [
    # deps file
    ":UapiGleFuzzTest",
  ]
}
###############################################################################
